# Copy to .env and adjust as needed

# Postgres
POSTGRES_DB=smart_waste
POSTGRES_USER=smart_waste
POSTGRES_PASSWORD=smart_waste
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost:5173

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC_PREFIX=bins

# AI service
AI_SERVICE_URL=http://ai-service:9000
AI_SERVICE_PORT=9000
YOLO_MODEL_PATH=./models/yolov8n.pt

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000

